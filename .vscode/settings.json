{
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "\\.(md|yml)$",  // .md 파일이나 .yml 파일이 저장될 때 실행!
                "isShell": true,
                "cmd": "python -m mkdocs build"
            }
        ]
    },
    "liveServer.settings.port": 5501,
    "liveServer.settings.root": "/site",
    "liveServer.settings.wait": 1000
}